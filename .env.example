# Local dev example:
VITE_API_BASE_URL=http://localhost:4000

# Vercel production example:
# Keep browser requests same-origin and let src/server.ts proxy /api/* to the
# backend using BACKEND_PROXY_URL, so auth does not depend on third-party
# cookies.
# VITE_API_BASE_URL=/api
# BACKEND_PROXY_URL=https://your-backend.onrender.com

# Pre-launch access gate (src/server.ts). Deliberately NOT prefixed with
# VITE_ — that prefix ships a value to the client bundle, which would leak
# these credentials. Set both only in the Vercel production environment
# (never in a committed .env) to lock the deployment down; leave unset
# locally so dev keeps working without a prompt.
# SITE_AUTH_USERNAME=
# SITE_AUTH_PASSWORD=
